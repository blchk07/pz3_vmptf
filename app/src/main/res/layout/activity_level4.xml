<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/level4Main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F3EA"
    android:padding="28dp"
    tools:context=".Level4Activity">

    <LinearLayout
        android:id="@+id/level4Container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/level4TitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Рівень 4"
            android:textAlignment="center"
            android:textColor="#242424"
            android:textSize="26sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/recipeNameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/input_default"
            android:fontFamily="sans-serif"
            android:hint="Назва рецепта"
            android:inputType="text"
            android:minHeight="48dp"
            android:textColor="#242424"
            android:textColorHint="#827B70"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/ingredientsEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/input_default"
            android:fontFamily="sans-serif"
            android:gravity="top"
            android:hint="Інгредієнти"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:minLines="2"
            android:textColor="#242424"
            android:textColorHint="#827B70"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/instructionsEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_default"
            android:fontFamily="sans-serif"
            android:gravity="top"
            android:hint="Інструкції приготування"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:minLines="2"
            android:textColor="#242424"
            android:textColorHint="#827B70"
            android:textSize="16sp" />

        <Button
            android:id="@+id/addRecipeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/button_default"
            android:fontFamily="sans-serif"
            android:text="Додати рецепт"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/recipesInfoTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif"
            android:text="Список рецептів порожній"
            android:textAlignment="center"
            android:textColor="#555047"
            android:textSize="16sp" />

        <ListView
            android:id="@+id/recipesListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#D6CFC2"
            android:dividerHeight="1dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>